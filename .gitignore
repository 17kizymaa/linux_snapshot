# === Security: never commit ===
.ssh/
.gnupg/
.private-keys-v1.d/
id_rsa
id_rsa.pub
*.pem
*.key

# === Shell history & auth ===
.bash_history
.zsh_history
.Xauthority
.ICEauthority
.dmrc

# === Cache & temp ===
.cache/
.local/
.npm/
.ollama/
.pytest_cache/
.trial_logs/
__pycache__/
*.pyc
*.pyo
node_modules/
venv/
.venv/

# === Large/binary downloads ===
Downloads/
*.m4a
*.mp3
*.mp4
*.zip
*.tar.gz
*.tar.xz
*.deb
*.rpm
*.iso
*.img

# === Desktop (usually shortcuts/junk) ===
Desktop/

# === wyld-application-v2: keep dir visible, but let global audio/video ignores apply ===
# (Voice recordings and large video belong inside the submodule with its own .gitignore,
# not committed here. The four file-pattern un-ignores that used to live below this
# comment were closed 2026-06-11 after they caused leaks scrubbed in 99efe83/704dcbf.)
!wyld-application-v2/

# === Symlinks to system libs ===
libwebp.so.*

# === Editor/IDE junk ===
*.swp
*.swo
*~
.vscode/
.idea/

# === OS noise ===
.xsession-errors
.xsession-errors.old
.thumbnails/
thumbnails/

# === Claude Code internal ===
.claude.json
.claude/

# === Browser data (huge, no value in snapshot) ===
.agent-chrome/
.config/chromium/

# === GSD planning (personal notes) ===
.planning/

