[Unit]
Description=Awareness Agent — Local Context Daemon
After=default.target

[Service]
Type=simple
ExecStart=%h/.local/bin/awareness serve
Restart=on-failure
RestartSec=5

Environment=XDG_CONFIG_HOME=%h/.config
Environment=XDG_DATA_HOME=%h/.local/share
Environment=XDG_STATE_HOME=%h/.local/state
Environment=XDG_RUNTIME_DIR=%t

NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.local/share/awareness-agent %h/.config/awareness-agent %h/.local/state/awareness-agent %t
PrivateTmp=yes
RestrictAddressFamilies=AF_UNIX

[Install]
WantedBy=default.target
